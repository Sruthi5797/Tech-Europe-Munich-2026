# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here

# Public HTTPS base URL of THIS server (e.g. an ngrok URL during the demo).
# Used to build the "Open LiverLink" button that Telegram is allowed to show.
# Must be https and publicly reachable, e.g. https://abcd-1234.ngrok-free.app
PUBLIC_BASE_URL=https://your-public-url.ngrok-free.app

# Custom URL scheme registered in Xcode (URL Types) for the iOS app.
APP_SCHEME=liverlink

# Optional: shared secret. If set, callers must send header  X-API-Key: <this>
API_KEY=

# Path to the JSON file storing patient_id -> telegram chat mapping.
PATIENTS_FILE=patients.json
